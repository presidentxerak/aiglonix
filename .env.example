# Supabase (project settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server only — NEVER exposed to the client, used by API routes
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile (anti-bot on signup/login) — optional, auth works without it
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Upstash Redis (rate limiting on /api/alerts) — optional, falls back to in-memory limiter
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Voice Map (Voice-to-Map). All optional — the module degrades gracefully:
# no Deepgram key → browser Web Speech API; no Mistral key → heuristic parser.
# Geocoding uses OpenStreetMap Nominatim (no key). Keys are SERVER-ONLY.
DEEPGRAM_API_KEY=
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
# Drone Sentinel aircraft identification (vision). Optional; falls back to the
# on-device YOLO class if unset. Uses MISTRAL_API_KEY above.
MISTRAL_VISION_MODEL=pixtral-large-latest

# Canonical production URL (anti-phishing notice, security.txt)
NEXT_PUBLIC_APP_URL=https://aiglonix.vercel.app
